PORT=3001
NODE_ENV=development

# ─── Banco de Dados (PostgreSQL) ────────────────────────────────────────────
# BUG CORRIGIDO: A variável DB_PATH (SQLite) foi substituída por DATABASE_URL (PostgreSQL)
# O código usa `pg` com Pool({ connectionString: DATABASE_URL })
# Preencha com sua URL do Railway, Supabase, Neon, etc.
# Exemplo local:  postgresql://postgres:senha@localhost:5432/cellmart
DATABASE_URL=https://eudesenrolo-production.up.railway.app

# BUG CORRIGIDO: SEED_ON_START estava ausente — admin nunca era criado automaticamente
SEED_ON_START=true

# JWT — MUDE EM PRODUÇÃO
JWT_SECRET=cellmart_jwt_super_secret_2024_mude_em_producao
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:5500

# Upload
MAX_FILE_SIZE=5242880
UPLOADS_DIR=./uploads/products
